    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.2.0",
    "socket.io": "^4.8.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.0"
  },
  "prisma": {
