# Database
DATABASE_URL=postgresql://medconnect:medconnect@localhost:5432/medconnect?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PLATFORM_FEE_PERCENT=1

# Twilio Video
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_API_KEY_SID=SKxxx
TWILIO_API_KEY_SECRET=xxx

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@medconnect.demo

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=medconnect-uploads

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NODE_ENV=development
LOG_LEVEL=info
REQUEST_TIMEOUT=30000
RETRY_ATTEMPTS=3
DB_CONNECTION_LIMIT=10
DB_POOL_TIMEOUT=10000
