# Database — PostgreSQL connection string
DATABASE_URL="postgresql://medconnect:medconnect@localhost:5432/medconnect?schema=public"

# Redis — Cache and queue backend
REDIS_URL="redis://localhost:6379"

# JWT (RS256) — Generate with: openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Application
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGINS="http://localhost:3001"

# Stripe — Payment processing (required for billing features)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Twilio — Video conferencing (required for telehealth video)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_API_KEY="SK..."
TWILIO_API_SECRET="..."

# Resend — Transactional email (optional)
RESEND_API_KEY="re_..."
