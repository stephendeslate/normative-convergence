generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  PLATFORM_ADMIN
  USER
}

enum MembershipRole {
  OWNER
  ADMIN
  PROVIDER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ConsultationType {
  VIDEO
  IN_PERSON
  PHONE
  BOTH
}

enum VideoRoomStatus {
  CREATED
  WAITING
  IN_PROGRESS
  COMPLETED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ConfirmationMode {
  AUTO_CONFIRM
  MANUAL_APPROVAL
}

enum CalendarProvider {
  GOOGLE
  OUTLOOK
}

enum CalendarEventDirection {
  OUTBOUND
  INBOUND
}

enum CalendarConnectionStatus {
  ACTIVE
  DISCONNECTED
}

enum MessageType {
  TEXT
  SYSTEM
}

enum IntakeFieldType {
  TEXT
  TEXTAREA
  SELECT
  MULTI_SELECT
  CHECKBOX
  DATE
  NUMBER
  PHONE
  EMAIL
}

enum IntakeStatus {
  PENDING
  COMPLETED
  NOT_REQUIRED
}

enum NotificationType {
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_REMINDER
  NEW_MESSAGE
  INTAKE_FORM_COMPLETED
  VIDEO_ROOM_READY
  PAYMENT_RECEIVED
  PAYMENT_REFUNDED
  PATIENT_IN_WAITING_ROOM
}

enum SpecialtyCategory {
  PRIMARY_CARE
  MENTAL_HEALTH
  DENTAL
  DERMATOLOGY
  PHYSICAL_THERAPY
  SPECIALIST
  OTHER
}

// ─── Platform Tables ────────────────────────────────────────────────────────

model Practice {
  id                       String             @id @default(uuid()) @db.Uuid
  name                     String             @db.VarChar(255)
  slug                     String             @unique @db.VarChar(100)
  description              String?            @db.Text
  category                 SpecialtyCategory
  logoUrl                  String?            @map("logo_url") @db.VarChar(500)
  coverPhotoUrl            String?            @map("cover_photo_url") @db.VarChar(500)
  brandColor               String?            @map("brand_color") @db.VarChar(7)
  timezone                 String             @db.VarChar(50)
  currency                 String             @default("USD") @db.VarChar(3)
  country                  String             @default("US") @db.VarChar(2)
  address                  Json?
  contactEmail             String?            @map("contact_email") @db.VarChar(255)
  contactPhone             String?            @map("contact_phone") @db.VarChar(20)
  stripeAccountId          String?            @map("stripe_account_id") @db.VarChar(255)
  stripeOnboarded          Boolean            @default(false) @map("stripe_onboarded")
  subscriptionTier         String             @default("STARTER") @map("subscription_tier") @db.VarChar(20)
  isPublished              Boolean            @default(false) @map("is_published")
  defaultCancellationPolicy Json?             @map("default_cancellation_policy")
  reminderSettings         Json               @default("{\"email_24h\": true, \"email_1h\": true, \"sms_1h\": false}") @map("reminder_settings")
  createdAt                DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  memberships       TenantMembership[]
  invitations       InvitationToken[]
  providerProfiles  ProviderProfile[]
  services          Service[]
  availabilityRules AvailabilityRule[]
  blockedDates      BlockedDate[]
  appointments      Appointment[]
  slotReservations  SlotReservation[]
  intakeTemplates   IntakeFormTemplate[]
  videoRooms        VideoRoom[]
  messages          Message[]
  paymentRecords    PaymentRecord[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  calendarConnections CalendarConnection[]

  @@map("practices")
}

model User {
  id                      String    @id @default(uuid()) @db.Uuid
  email                   String    @unique @db.VarChar(255)
  passwordHash            String?   @map("password_hash") @db.VarChar(255)
  name                    String    @db.VarChar(255)
  phone                   String?   @db.VarChar(20)
  avatarUrl               String?   @map("avatar_url") @db.VarChar(500)
  role                    UserRole  @default(USER)
  emailVerified           Boolean   @default(false) @map("email_verified")
  googleId                String?   @unique @map("google_id") @db.VarChar(255)
  dateOfBirth             DateTime? @map("date_of_birth") @db.Date
  gender                  String?   @db.VarChar(20)
  locale                  String    @default("en") @db.VarChar(10)
  timezone                String?   @db.VarChar(50)
  notificationPreferences Json      @default("{\"email\": true, \"sms\": false, \"push\": false}") @map("notification_preferences")
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  memberships     TenantMembership[]
  refreshTokens   RefreshToken[]
  providerProfile ProviderProfile[]
  appointments    Appointment[]      @relation("PatientAppointments")
  cancelledAppointments Appointment[] @relation("CancelledByUser")
  sentMessages    Message[]          @relation("SentMessages")
  receivedMessages Message[]         @relation("ReceivedMessages")
  notifications   Notification[]
  auditLogs       AuditLog[]
  videoParticipants VideoParticipant[]
  invitationsSent InvitationToken[]
  calendarConnections CalendarConnection[]
  consentRecords  ConsentRecord[]

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz()
  replacedBy String?   @map("replaced_by") @db.Uuid
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  userAgent  String?   @map("user_agent") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_tokens_user")
  @@map("refresh_tokens")
}

model TenantMembership {
  id         String         @id @default(uuid()) @db.Uuid
  practiceId String         @map("practice_id") @db.Uuid
  userId     String         @map("user_id") @db.Uuid
  role       MembershipRole
  isActive   Boolean        @default(true) @map("is_active")
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([practiceId, userId])
  @@map("tenant_memberships")
}

model InvitationToken {
  id         String         @id @default(uuid()) @db.Uuid
  practiceId String         @map("practice_id") @db.Uuid
  email      String         @db.VarChar(255)
  role       MembershipRole @default(PROVIDER)
  tokenHash  String         @unique @map("token_hash") @db.VarChar(64)
  invitedBy  String         @map("invited_by") @db.Uuid
  expiresAt  DateTime       @map("expires_at") @db.Timestamptz()
  acceptedAt DateTime?      @map("accepted_at") @db.Timestamptz()
  revokedAt  DateTime?      @map("revoked_at") @db.Timestamptz()
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz()

  practice  Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  inviter   User     @relation(fields: [invitedBy], references: [id])

  @@index([tokenHash], map: "idx_invitation_tokens_hash")
  @@index([practiceId, email], map: "idx_invitation_tokens_practice_email")
  @@map("invitation_tokens")
}

// ─── Provider Tables ────────────────────────────────────────────────────────

model ProviderProfile {
  id                   String             @id @default(uuid()) @db.Uuid
  practiceId           String             @map("practice_id") @db.Uuid
  userId               String             @map("user_id") @db.Uuid
  specialties          String[]           @default([])
  credentials          String?            @db.VarChar(100)
  bio                  String?            @db.Text
  yearsOfExperience    Int?               @map("years_of_experience")
  education            String?            @db.Text
  languages            String[]           @default(["English"])
  acceptingNewPatients Boolean            @default(true) @map("accepting_new_patients")
  consultationTypes    ConsultationType[] @default([VIDEO]) @map("consultation_types")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  practice          Practice           @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceProviders  ServiceProvider[]
  availabilityRules AvailabilityRule[]
  blockedDates      BlockedDate[]
  appointments      Appointment[]
  slotReservations  SlotReservation[]

  @@unique([practiceId, userId])
  @@map("provider_profiles")
}

model Service {
  id                    String           @id @default(uuid()) @db.Uuid
  practiceId            String           @map("practice_id") @db.Uuid
  name                  String           @db.VarChar(255)
  description           String?          @db.Text
  durationMinutes       Int              @map("duration_minutes")
  price                 Decimal          @default(0.00) @db.Decimal(10, 2)
  consultationType      ConsultationType @default(VIDEO) @map("consultation_type")
  confirmationMode      ConfirmationMode @default(AUTO_CONFIRM) @map("confirmation_mode")
  intakeFormTemplateId  String?          @map("intake_form_template_id") @db.Uuid
  maxParticipants       Int              @default(2) @map("max_participants")
  bufferBeforeMinutes   Int              @default(0) @map("buffer_before_minutes")
  bufferAfterMinutes    Int              @default(0) @map("buffer_after_minutes")
  category              String?          @db.VarChar(100)
  isActive              Boolean          @default(true) @map("is_active")
  sortOrder             Int              @default(0) @map("sort_order")
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime         @updatedAt @map("updated_at") @db.Timestamptz()

  practice         Practice           @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  intakeTemplate   IntakeFormTemplate? @relation(fields: [intakeFormTemplateId], references: [id])
  serviceProviders ServiceProvider[]
  appointments     Appointment[]

  @@map("services")
}

model ServiceProvider {
  id                String @id @default(uuid()) @db.Uuid
  serviceId         String @map("service_id") @db.Uuid
  providerProfileId String @map("provider_profile_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()

  service  Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  provider ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@unique([serviceId, providerProfileId])
  @@map("service_providers")
}

// ─── Scheduling Tables ──────────────────────────────────────────────────────

model AvailabilityRule {
  id                  String  @id @default(uuid()) @db.Uuid
  practiceId          String  @map("practice_id") @db.Uuid
  providerProfileId   String  @map("provider_profile_id") @db.Uuid
  dayOfWeek           Int     @map("day_of_week")
  startTime           String  @map("start_time") @db.VarChar(5)
  endTime             String  @map("end_time") @db.VarChar(5)
  slotDurationMinutes Int     @map("slot_duration_minutes")
  isActive            Boolean @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  practice Practice        @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  provider ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@map("availability_rules")
}

model BlockedDate {
  id                String   @id @default(uuid()) @db.Uuid
  practiceId        String   @map("practice_id") @db.Uuid
  providerProfileId String   @map("provider_profile_id") @db.Uuid
  startDate         DateTime @map("start_date") @db.Date
  endDate           DateTime @map("end_date") @db.Date
  reason            String?  @db.VarChar(255)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()

  practice Practice        @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  provider ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@map("blocked_dates")
}

// ─── Appointment Tables ─────────────────────────────────────────────────────

model Appointment {
  id                String            @id @default(uuid()) @db.Uuid
  practiceId        String            @map("practice_id") @db.Uuid
  providerProfileId String            @map("provider_profile_id") @db.Uuid
  patientId         String            @map("patient_id") @db.Uuid
  serviceId         String            @map("service_id") @db.Uuid
  startTime         DateTime          @map("start_time") @db.Timestamptz()
  endTime           DateTime          @map("end_time") @db.Timestamptz()
  status            AppointmentStatus @default(PENDING)
  consultationType  ConsultationType  @map("consultation_type")
  notes             String?           @db.Text
  cancellationReason String?          @map("cancellation_reason") @db.Text
  cancelledBy       String?           @map("cancelled_by") @db.Uuid
  cancelledAt       DateTime?         @map("cancelled_at") @db.Timestamptz()
  checkedInAt       DateTime?         @map("checked_in_at") @db.Timestamptz()
  completedAt       DateTime?         @map("completed_at") @db.Timestamptz()
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz()

  practice         Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  provider         ProviderProfile   @relation(fields: [providerProfileId], references: [id])
  patient          User              @relation("PatientAppointments", fields: [patientId], references: [id])
  service          Service           @relation(fields: [serviceId], references: [id])
  cancelledByUser  User?             @relation("CancelledByUser", fields: [cancelledBy], references: [id])
  videoRoom        VideoRoom?
  intakeSubmission IntakeSubmission?
  paymentRecord    PaymentRecord?
  messages         Message[]
  reminders        AppointmentReminder[]

  @@unique([providerProfileId, startTime])
  @@index([patientId, startTime], map: "idx_appointments_patient")
  @@index([practiceId, startTime], map: "idx_appointments_practice_date")
  @@index([practiceId, status], map: "idx_appointments_status")
  @@map("appointments")
}

model SlotReservation {
  id                String   @id @default(uuid()) @db.Uuid
  practiceId        String   @map("practice_id") @db.Uuid
  providerProfileId String   @map("provider_profile_id") @db.Uuid
  startTime         DateTime @map("start_time") @db.Timestamptz()
  endTime           DateTime @map("end_time") @db.Timestamptz()
  sessionId         String   @map("session_id") @db.VarChar(255)
  expiresAt         DateTime @map("expires_at") @db.Timestamptz()
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()

  practice Practice        @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  provider ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@unique([providerProfileId, startTime])
  @@map("slot_reservations")
}

// ─── Video Tables ───────────────────────────────────────────────────────────

model VideoRoom {
  id                    String          @id @default(uuid()) @db.Uuid
  practiceId            String          @map("practice_id") @db.Uuid
  appointmentId         String          @unique @map("appointment_id") @db.Uuid
  twilioRoomSid         String          @map("twilio_room_sid") @db.VarChar(255)
  twilioRoomName        String          @map("twilio_room_name") @db.VarChar(255)
  status                VideoRoomStatus @default(CREATED)
  maxParticipants       Int             @default(2) @map("max_participants")
  startedAt             DateTime?       @map("started_at") @db.Timestamptz()
  endedAt               DateTime?       @map("ended_at") @db.Timestamptz()
  actualDurationSeconds Int?            @map("actual_duration_seconds")
  createdAt             DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime        @updatedAt @map("updated_at") @db.Timestamptz()

  practice     Practice           @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  appointment  Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  participants VideoParticipant[]

  @@map("video_rooms")
}

model VideoParticipant {
  id                    String    @id @default(uuid()) @db.Uuid
  videoRoomId           String    @map("video_room_id") @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  twilioParticipantSid  String?   @map("twilio_participant_sid") @db.VarChar(255)
  joinedAt              DateTime? @map("joined_at") @db.Timestamptz()
  leftAt                DateTime? @map("left_at") @db.Timestamptz()
  durationSeconds       Int?      @map("duration_seconds")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  videoRoom VideoRoom @relation(fields: [videoRoomId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@map("video_participants")
}

// ─── Intake Form Tables ─────────────────────────────────────────────────────

model IntakeFormTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  practiceId  String   @map("practice_id") @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  fields      Json
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  practice    Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  services    Service[]
  submissions IntakeSubmission[]

  @@map("intake_form_templates")
}

model IntakeSubmission {
  id         String       @id @default(uuid()) @db.Uuid
  practiceId String       @map("practice_id") @db.Uuid
  appointmentId String    @unique @map("appointment_id") @db.Uuid
  templateId String       @map("template_id") @db.Uuid
  responses  Json
  status     IntakeStatus @default(PENDING)
  completedAt DateTime?   @map("completed_at") @db.Timestamptz()
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime     @updatedAt @map("updated_at") @db.Timestamptz()

  appointment Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  template    IntakeFormTemplate  @relation(fields: [templateId], references: [id])

  @@map("intake_submissions")
}

// ─── Communication Tables ───────────────────────────────────────────────────

model Message {
  id            String      @id @default(uuid()) @db.Uuid
  practiceId    String      @map("practice_id") @db.Uuid
  appointmentId String      @map("appointment_id") @db.Uuid
  senderId      String      @map("sender_id") @db.Uuid
  receiverId    String      @map("receiver_id") @db.Uuid
  content       String      @db.Text
  type          MessageType @default(TEXT)
  readAt        DateTime?   @map("read_at") @db.Timestamptz()
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  practice    Practice    @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  sender      User        @relation("SentMessages", fields: [senderId], references: [id])
  receiver    User        @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([appointmentId, createdAt], map: "idx_messages_appointment")
  @@map("messages")
}

model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  practiceId String           @map("practice_id") @db.Uuid
  userId     String           @map("user_id") @db.Uuid
  type       NotificationType
  title      String           @db.VarChar(255)
  body       String           @db.Text
  data       Json?
  readAt     DateTime?        @map("read_at") @db.Timestamptz()
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt], map: "idx_notifications_user_unread")
  @@map("notifications")
}

model AppointmentReminder {
  id            String   @id @default(uuid()) @db.Uuid
  appointmentId String   @map("appointment_id") @db.Uuid
  channel       String   @db.VarChar(10)
  scheduledFor  DateTime @map("scheduled_for") @db.Timestamptz()
  sentAt        DateTime? @map("sent_at") @db.Timestamptz()
  jobId         String?  @map("job_id") @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([scheduledFor], map: "idx_reminders_scheduled")
  @@map("appointment_reminders")
}

// ─── Payment Tables ─────────────────────────────────────────────────────────

model PaymentRecord {
  id                    String        @id @default(uuid()) @db.Uuid
  practiceId            String        @map("practice_id") @db.Uuid
  appointmentId         String        @unique @map("appointment_id") @db.Uuid
  stripePaymentIntentId String?       @map("stripe_payment_intent_id") @db.VarChar(255)
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("USD") @db.VarChar(3)
  platformFee           Decimal       @default(0) @map("platform_fee") @db.Decimal(10, 2)
  status                PaymentStatus @default(PENDING)
  refundedAmount        Decimal?      @map("refunded_amount") @db.Decimal(10, 2)
  metadata              Json?
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  practice    Practice    @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("payment_records")
}

// ─── Calendar Sync Tables ───────────────────────────────────────────────────

model CalendarConnection {
  id           String                   @id @default(uuid()) @db.Uuid
  userId       String                   @map("user_id") @db.Uuid
  practiceId   String                   @map("practice_id") @db.Uuid
  provider     CalendarProvider
  accessToken  String                   @map("access_token") @db.Text
  refreshToken String                   @map("refresh_token") @db.Text
  expiresAt    DateTime                 @map("expires_at") @db.Timestamptz()
  calendarId   String                   @map("calendar_id") @db.VarChar(255)
  status       CalendarConnectionStatus @default(ACTIVE)
  createdAt    DateTime                 @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime                 @updatedAt @map("updated_at") @db.Timestamptz()

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  practice Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  events   CalendarEvent[]

  @@unique([userId, practiceId, provider])
  @@map("calendar_connections")
}

model CalendarEvent {
  id                   String                 @id @default(uuid()) @db.Uuid
  calendarConnectionId String                 @map("calendar_connection_id") @db.Uuid
  externalEventId      String                 @map("external_event_id") @db.VarChar(255)
  direction            CalendarEventDirection
  title                String                 @db.VarChar(255)
  startTime            DateTime               @map("start_time") @db.Timestamptz()
  endTime              DateTime               @map("end_time") @db.Timestamptz()
  syncedAt             DateTime               @map("synced_at") @db.Timestamptz()
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz()

  connection CalendarConnection @relation(fields: [calendarConnectionId], references: [id], onDelete: Cascade)

  @@unique([calendarConnectionId, externalEventId])
  @@map("calendar_events")
}

// ─── Audit & Compliance Tables ──────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  resource   String   @db.VarChar(100)
  resourceId String   @map("resource_id") @db.VarChar(255)
  details    Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([practiceId, createdAt], map: "idx_audit_logs_practice")
  @@index([userId, createdAt], map: "idx_audit_logs_user")
  @@index([resource, resourceId], map: "idx_audit_logs_resource")
  @@map("audit_logs")
}

model ConsentRecord {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  granted   Boolean
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type], map: "idx_consent_records_user_type")
  @@map("consent_records")
}
